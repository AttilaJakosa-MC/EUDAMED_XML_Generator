me":"buttonList","waitForSelector":false,"waitSelectorTimeout":5000},"id":"jaowaw3","initialized":false,"label":"loop-data","position":{"x":134.00764929913043,"y":318.14009462563854},"type":"BlockBasic"},{"data":{"disableBlock":false,"time":"2000"},"id":"2mbava7","initialized":false,"label":"delay","position":{"x":615.6415988100939,"y":326.6664673762702},"type":"BlockDelay"},{"data":{"clearLoop":false,"disableBlock":false,"loopId":"downloadLoop"},"id":"kn4axjq","initialized":false,"label":"loop-breakpoint","position":{"x":1379.198027968574,"y":295.6833390075315},"type":"BlockLoopBreakpoint"},{"data":{"disableBlock":false},"id":"q2q1zw0","initialized":false,"label":"active-tab","position":{"x":865.0599577827302,"y":59.537174753432225},"type":"BlockBasic"},{"data":{"code":"// 1. Enter the iframe\nconst iframe = document.querySelector('iframe[id^=\"__container\"]');\nconst doc = iframe.contentDocument || iframe.contentWindow.document;\n\n// 2. Grab every single Download button currently attached to the table\nconst buttons = doc.querySelectorAll('tbody[id$=\"eudamed-results-innerTable-tblBody\"] button[title=\"Download\"]');\n\n// 3. Create an array of indexes based on how many buttons were found (e.g., [0, 1, 2...])\nconst buttonList = Array.from({ length: buttons.length }, (_, i) => ({ index: i }));\n\nif (buttonList.length === 0) {\n    alert(\"No download buttons found on the page!\");\n    throw new Error(\"No buttons found\");\n}\n\n// 4. Save this array to an Automa variable so we can loop through it\nautomaSetVariable('buttonList', buttonList);\nautomaNextBlock();","context":"website","description":"","disableBlock":false,"everyNewTab":false,"preloadScripts":[],"runBeforeLoad":false,"timeout":5000},"id":"2pkncmy","initialized":false,"label":"javascript-code","position":{"x":1556,"y":84.1609347055996},"type":"BlockBasic"},{"data":{"code":"// 1. Enter the iframe\nconst iframe = document.querySelector('iframe[id^=\"__container\"]');\nconst doc = iframe.contentDocument || iframe.contentWindow.document;\n\n// 2. Safely get the current loop index\nconst loopObj = automaRefData('loopData', 'downloadLoop');\n// We pull the index directly from the data object we created in the finder block\nconst currentIndex = loopObj && loopObj.data ? loopObj.data.index : (loopObj.$index || 0);\n\n// 3. Find the buttons\nconst buttons = doc.querySelectorAll('tbody[id$=\"eudamed-results-innerTable-tblBody\"] button[title=\"Download\"]');\nconst targetButton = buttons[currentIndex];\n\n// 4. Force perfectly simulated human clicks for SAP UI5\nif (targetButton) {\n    targetButton.focus();\n    \n    // SAP UI5 strictly listens for mousedown -> mouseup -> click sequences\n    ['mousedown', 'mouseup', 'click'].forEach(eventType => {\n        const mouseEvent = new MouseEvent(eventType, {\n            bubbles: true,\n            cancelable: true,\n            view: iframe.contentWindow,\n            buttons: 1\n        });\n        targetButton.dispatchEvent(mouseEvent);\n    });\n    \n} else {\n    throw new Error(\"Could not find button at index: \" + currentIndex);\n}\n\nautomaNextBlock();","context":"website","description":"","disableBlock":false,"everyNewTab":false,"preloadScripts":[],"runBeforeLoad":false,"timeout":20000},"id":"dykgazw","initialized":false,"label":"javascript-code","position":{"x":1008.1552146168199,"y":346.9098650275207},"type":"BlockBasic"}],"position":[45.974322191952524,133.7341698147311],"viewport":{"x":45.974322191952524,"y":133.7341698147311,"zoom":0.5455763852960892},"zoom":0.5455763852960892},"settings":{"aipowerToken":"","blockDelay":0,"debugMode":false,"defaultColumnName":"column","execContext":"popup","executedBlockOnWeb":false,"inputAutocomplete":true,"insertDefaultColumn":false,"notification":true,"onError":"stop-workflow","publicId":"","restartTimes":3,"reuseLastState":false,"saveLog":true},"globalData":"{\n\t\"key\": \"value\"\n}","description":"Insert an excel copied data table into the Kontron Eudamed applica